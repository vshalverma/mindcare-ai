# --- Data (large; recreate via the data pipeline) ---
data/raw/
data/processed/

# --- HuggingFace encoder cache (large; auto-downloaded on first use) ---
models/encoder/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.idea/
.vscode/

# --- Virtual envs / secrets ---
venv/
.env

# --- Trained model artifacts (mostly small + tracked; large weights are not) ---
# models/checkpoints/final/ holds the trained model. We track the small
# config/tokenizer/label-map/metrics files but NOT the large weight binaries.
# To run the demo after a fresh clone, retrain (see README "Setup" / PROJECT_REPORT.md).
models/checkpoints/*
!models/checkpoints/final/
!models/checkpoints/final/*.json
!models/checkpoints/final/*.txt
models/checkpoints/final/*.safetensors
models/checkpoints/final/*.bin
!models/checkpoints/final/training_args.bin

# --- Streamlit ---
.streamlit/secrets.toml